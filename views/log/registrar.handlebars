<div id="fadeCadastrado" class="hide"></div>
<div id="modalCadastrado" class="hide">
    <h3>Cadastrado com sucesso. Voce sera redirecionado.</h3>
</div>

<div class="main">
        <section class="sectionForm">
        <div class="titleLogin">
            <h1>Cadastre-se</h1>
            <span class="span0"></span>
        </div>
        <form action="/cadastrado" method="POST" id="cadastrarForm">
                <input type="text" name="nome" id="nome" placeholder="Nome" autocomplete="off">
                <span class="span1"></span>
                <input type="text" name="sobrenome" id="sobrenome" placeholder="Sobrenome" autocomplete="off">
                <span class="span2"></span>
                <input type="text" name="endereco" id="endereco" placeholder="Endereco" autocomplete="off">
                <span class="span2"></span>
                <input type="text" name="telefone" id="telefone" placeholder="Telefone" autocomplete="off">
                <span class="span2"></span>
                <input type="text" name="dataNasc" id="dataNasc" placeholder="Data de Nascimento" autocomplete="off">
                <span class="span2"></span>
                <input type="text" name="cpf" id="cpf" placeholder="CPF" autocomplete="off">
                <span class="span2"></span>
                <input type="email" name="email" id="email" placeholder="Email" autocomplete="off">
                <span class="span3"></span>
                <input type="password" name="senha" id="senha" placeholder="Senha" autocomplete="off">
                <span class="span4"></span>
                <input type="password" id="confirmeSenha" placeholder="Confirme sua senha" autocomplete="off">
                <span class="span5"></span>
                <p class="semConta">Ou entre sem cadastro clicando <a href="/">aqui!</a></p>
                <button type="submit" id="entrar">Cadastrar</button>
        </form>
    </section>
        <section class="sectionInfos">
        <div class="titleInfos">
            <h2>Já tem uma conta?</h2>
        </div>
        <p>Entre agora para aproveitar o melhor do nosso site.</p>
        <a href="/login" id="cadastrar">Entrar</a>
    </section>
</div>